# Enable the integrated Discord Social SDK bridge inside src/server/main.ts.
DISCORD_SOCIAL_BRIDGE_ENABLED=true
DISCORD_SOCIAL_APP_ID=1447954255452311695
DISCORD_SOCIAL_BRIDGE_CHANNEL_ID=1486055498691383419
DISCORD_SOCIAL_DEVICE_FLOW=true
DISCORD_SOCIAL_ENABLE_CHANNEL_LINKING=true
DISCORD_SOCIAL_BRIDGE_LOG_PAYLOADS=false

# Optional: override the native bridge executable path if you do not use the default build output.
# DISCORD_SOCIAL_BRIDGE_EXECUTABLE=/absolute/path/to/discord_social_bridge

# Required for granting CanLinkLobby before linking the Discord channel to the lobby.
DISCORD_BOT_TOKEN=your_bot_token_here

# Linked Roles API configuration hosted directly by the local Dungeon Blitz server.
DISCORD_APPLICATION_ID=1447954255452311695
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_APP_PUBLIC_KEY=your_app_public_key_here

# Optional: override if Discord's registered redirect URI should not be derived from the current request host.
# DISCORD_LINKED_ROLES_REDIRECT_URI=http://localhost:8000/api/discord-linked-roles/callback

# Optional but recommended: separate signing secret for the Linked Roles OAuth state.
# DISCORD_LINKED_ROLES_STATE_SECRET=replace_with_random_secret

# Optional sponsor flags for Linked Roles. Comma-separate multiple values.
# DISCORD_LINKED_ROLES_SPONSOR_ACCOUNT_IDS=1,2,3
# DISCORD_LINKED_ROLES_SPONSOR_EMAILS=alice@example.com,bob@example.com
